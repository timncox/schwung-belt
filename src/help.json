{
  "title": "Belt",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "Live vocal",
        "processor.",
        "",
        "Autotune pitch",
        "correction, up to",
        "4 backing-vocal",
        "harmonies in key,",
        "a stereo doubler,",
        "and formant shift.",
        "",
        "Works in chain",
        "slots and Master",
        "FX. For the mic,",
        "use Belt In."
      ]
    },
    {
      "title": "Quick Start",
      "lines": [
        "1. Set Key + Scale",
        " to your song.",
        "2. Retune low =",
        " natural, 0 =",
        " hard-tune robot.",
        "3. Pads 1-4 turn",
        " harmony voices",
        " on. Shift+pad",
        " picks interval.",
        "4. HARD pad =",
        " instant T-Pain.",
        "",
        "Steps 1-12 show",
        "your note: green",
        "in tune, orange",
        "off. Press one to",
        "set the Key."
      ]
    },
    {
      "title": "Knobs",
      "children": [
        {
          "title": "Main Knobs",
          "lines": [
            "1: Key",
            "2: Scale",
            "3: Retune speed",
            " 0 = instant",
            " high = gentle",
            "4: Amount",
            "5: Harmony level",
            "6: Doubler",
            "7: Formant",
            " - deep + bright",
            "8: Wet",
            " corrected vs",
            " dry lead"
          ]
        },
        {
          "title": "Shift Knobs",
          "lines": [
            "1: Humanize",
            " keeps vibrato,",
            " loosens voices",
            "2: Flex",
            " leaves slides",
            " between notes",
            " untouched",
            "3: Spread",
            " harmony stereo",
            " width",
            "4: Monitor",
            " (Belt In only)"
          ]
        }
      ]
    },
    {
      "title": "MIDI Notes",
      "lines": [
        "Play notes at Belt",
        "from pads, clips,",
        "or a keyboard:",
        "",
        "HARMONY mode:",
        "held notes become",
        "the harmony - hold",
        "a chord, sing, the",
        "voices sing those",
        "exact notes. Clip",
        "chords work under",
        "an overtake too.",
        "",
        "TARGET mode:",
        "your voice is",
        "pulled to the held",
        "note. Play the",
        "melody, sing away.",
        "",
        "Vel Sens: velocity",
        "sets voice volume.",
        "",
        "Control notes",
        "(C-2 range):",
        "0 = HARD while",
        " held",
        "1 = full doubler",
        "2 = mute harmonies",
        "",
        "Set mode with",
        "Shift+knob 6 or",
        "Perform page."
      ]
    },
    {
      "title": "Hard Tune",
      "lines": [
        "Hard Tune is a",
        "real parameter",
        "(Perform page,",
        "Shift+knob 5).",
        "",
        "On = instant full",
        "correction, your",
        "Retune and Amount",
        "knobs untouched.",
        "",
        "HARD pad: tap =",
        "latch, hold = only",
        "while held.",
        "MIDI note 0 does",
        "the same from a",
        "clip or keyboard."
      ]
    },
    {
      "title": "Pads",
      "lines": [
        "68-71: harmony",
        " voices 1-4.",
        " Tap = on/off.",
        " Shift+tap =",
        " next interval.",
        "76: HARD punch.",
        " Tap = latch,",
        " hold = while",
        " held only.",
        "73: Monitor",
        " (Belt In only).",
        "",
        "Steps 13-16 show",
        "active voices."
      ]
    },
    {
      "title": "Tips",
      "lines": [
        "Wet 0 + harmonies",
        "on = natural lead",
        "with tuned backup",
        "singers.",
        "",
        "Doubler + a bit",
        "of Humanize is",
        "instant chorus",
        "thickness.",
        "",
        "Formant down =",
        "bigger, formant",
        "up = brighter."
      ]
    }
  ]
}
