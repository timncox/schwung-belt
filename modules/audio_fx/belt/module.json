{
  "id": "belt",
  "name": "Belt",
  "abbrev": "BELT",
  "version": "0.1.0",
  "description": "Live vocal processor: autotune pitch correction, diatonic backing-vocal harmonies, doubler, and formant shift",
  "dsp": "belt.so",
  "ui_chain": "ui_chain.js",
  "api_version": 2,
  "component_type": "audio_fx",
  "capabilities": {
    "chainable": true,
    "component_type": "audio_fx",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "name": "Belt",
          "params": [
            {
              "key": "key",
              "name": "Key",
              "type": "enum",
              "options": [
                "C",
                "C#",
                "D",
                "D#",
                "E",
                "F",
                "F#",
                "G",
                "G#",
                "A",
                "A#",
                "B"
              ],
              "default": 0
            },
            {
              "key": "scale",
              "name": "Scale",
              "type": "enum",
              "options": [
                "Chromatic",
                "Major",
                "Minor",
                "Harm Min",
                "Dorian",
                "Mixo",
                "Maj Pent",
                "Min Pent",
                "Blues"
              ],
              "default": 1
            },
            {
              "key": "retune",
              "name": "Retune",
              "type": "float",
              "min": 0,
              "max": 100,
              "default": 25,
              "step": 5,
              "unit": "%",
              "display_format": "%.0f"
            },
            {
              "key": "amount",
              "name": "Amount",
              "type": "float",
              "min": 0,
              "max": 100,
              "default": 100,
              "step": 5,
              "unit": "%",
              "display_format": "%.0f"
            },
            {
              "level": "harmony",
              "name": "Harmony"
            },
            {
              "level": "setup",
              "name": "Setup"
            }
          ],
          "knobs": [
            "key",
            "scale",
            "retune",
            "amount"
          ]
        },
        "harmony": {
          "name": "Harmony",
          "params": [
            {
              "key": "harm1",
              "name": "Voice 1",
              "type": "enum",
              "options": [
                "Off",
                "-Oct",
                "-6th",
                "-5th",
                "-4th",
                "-3rd",
                "Unis",
                "+3rd",
                "+4th",
                "+5th",
                "+6th",
                "+Oct"
              ],
              "default": 0
            },
            {
              "key": "harm2",
              "name": "Voice 2",
              "type": "enum",
              "options": [
                "Off",
                "-Oct",
                "-6th",
                "-5th",
                "-4th",
                "-3rd",
                "Unis",
                "+3rd",
                "+4th",
                "+5th",
                "+6th",
                "+Oct"
              ],
              "default": 0
            },
            {
              "key": "harm3",
              "name": "Voice 3",
              "type": "enum",
              "options": [
                "Off",
                "-Oct",
                "-6th",
                "-5th",
                "-4th",
                "-3rd",
                "Unis",
                "+3rd",
                "+4th",
                "+5th",
                "+6th",
                "+Oct"
              ],
              "default": 0
            },
            {
              "key": "harm4",
              "name": "Voice 4",
              "type": "enum",
              "options": [
                "Off",
                "-Oct",
                "-6th",
                "-5th",
                "-4th",
                "-3rd",
                "Unis",
                "+3rd",
                "+4th",
                "+5th",
                "+6th",
                "+Oct"
              ],
              "default": 0
            },
            {
              "key": "harm_level",
              "name": "Harm Level",
              "type": "float",
              "min": 0,
              "max": 100,
              "default": 80,
              "step": 5,
              "unit": "%",
              "display_format": "%.0f"
            },
            {
              "key": "spread",
              "name": "Spread",
              "type": "float",
              "min": 0,
              "max": 100,
              "default": 70,
              "step": 5,
              "unit": "%",
              "display_format": "%.0f"
            },
            {
              "key": "double_amt",
              "name": "Doubler",
              "type": "float",
              "min": 0,
              "max": 100,
              "default": 0,
              "step": 5,
              "unit": "%",
              "display_format": "%.0f"
            }
          ],
          "knobs": [
            "harm1",
            "harm2",
            "harm_level",
            "double_amt"
          ]
        },
        "setup": {
          "name": "Setup",
          "params": [
            {
              "key": "wet",
              "name": "Wet",
              "type": "float",
              "min": 0,
              "max": 100,
              "default": 100,
              "step": 5,
              "unit": "%",
              "display_format": "%.0f"
            },
            {
              "key": "formant",
              "name": "Formant",
              "type": "int",
              "min": -100,
              "max": 100,
              "default": 0,
              "step": 5
            },
            {
              "key": "flex",
              "name": "Flex",
              "type": "float",
              "min": 0,
              "max": 100,
              "default": 0,
              "step": 5,
              "unit": "%",
              "display_format": "%.0f"
            },
            {
              "key": "humanize",
              "name": "Humanize",
              "type": "float",
              "min": 0,
              "max": 100,
              "default": 30,
              "step": 5,
              "unit": "%",
              "display_format": "%.0f"
            }
          ],
          "knobs": [
            "wet",
            "formant",
            "flex",
            "humanize"
          ]
        }
      }
    }
  },
  "author": "timncox"
}
